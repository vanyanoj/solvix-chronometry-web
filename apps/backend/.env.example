# .env.example — шаблон env-переменных для бэка.
# Скопируй в .env и подправь под себя (или оставь как есть — дефолты ОК для локалки).
# Сам .env должен быть в .gitignore (не коммитим креды).

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://solvix:solvix_dev_password@localhost:5432/solvix_chronometry

# --- MQTT (Mosquitto) ---
# localhost — бэк из venv, mosquitto-контейнер с проброшенным портом
# mosquitto — бэк сам в docker-compose, ходит по имени сервиса в Docker-сети
MQTT_HOST=localhost
MQTT_PORT=1883

# --- Окружение ---
APP_ENV=development

# JWT — секрет для подписи токенов
# Генерация: python -c 'import secrets; print(secrets.token_urlsafe(64))'
JWT_SECRET_KEY=replace_me_with_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=720  # 12 часов = одна смена

# CORS: список origins фронтенда (JSON)
CORS_ORIGINS=["http://192.168.1.10:5173"]
