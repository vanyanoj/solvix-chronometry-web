# Скопируй в .env (он в .gitignore) и заполни.
# Все эти переменные подхватываются как docker-compose, так и backend-приложением.

POSTGRES_USER=solvix
POSTGRES_PASSWORD=solvix_dev_password
POSTGRES_DB=solvix_chronometry

# Для backend (если запускаешь не в docker-compose, а локально):
DATABASE_URL=postgresql+asyncpg://solvix:solvix_dev_password@localhost:5432/solvix_chronometry

MQTT_HOST=localhost
MQTT_PORT=1883

APP_ENV=development
